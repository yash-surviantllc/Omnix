# Application
APP_NAME=Manufacturing OS
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# JWT
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=30
